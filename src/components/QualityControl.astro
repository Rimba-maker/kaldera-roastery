---
const cards = [
  {
    icon: "🔬",
    title: "Cupping Setiap Batch",
    description: "Tim Q-Grader internal cupping tiap lot sebelum dilepas ke pasar",
  },
  {
    icon: "📋",
    title: "Traceability Penuh",
    description: "Tahu persis kebun, kelompok tani, dan tanggal panen setiap origin",
  },
  {
    icon: "🌡️",
    title: "Penyimpanan Terkontrol",
    description: "Green bean disimpan di gudang bersuhu & kelembaban terjaga",
  },
  {
    icon: "📄",
    title: "Spec Sheet Tersedia",
    description: "Setiap origin punya dokumen cupping score, moisture content, defect count",
  },
];
---

<section id="quality" class="mx-auto max-w-[1280px] px-6 py-24">
  <h2 class="text-3xl font-bold tracking-tight md:text-4xl">
    Kualitas Yang Bisa Dipertanggungjawabkan.
  </h2>

  <div class="mt-8 grid gap-6 sm:grid-cols-2">
    <img
      src="https://images.unsplash.com/photo-1558996225-97c962538cb3?q=80&w=800&auto=format&fit=crop"
      alt="Cupping session"
      class="aspect-[4/3] w-full rounded-lg border border-hairline object-cover"
    />
    <img
      src="https://images.unsplash.com/photo-1746623691157-c4c7a3bad0c4?q=80&w=800&auto=format&fit=crop"
      alt="Kebun kopi petani"
      class="aspect-[4/3] w-full rounded-lg border border-hairline object-cover"
    />
  </div>

  <div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
    {
      cards.map((card) => (
        <div class="rounded-lg border border-hairline bg-surface-card p-6">
          <span class="text-2xl">{card.icon}</span>
          <h3 class="mt-3 font-semibold">{card.title}</h3>
          <p class="mt-1 text-sm text-body">{card.description}</p>
        </div>
      ))
    }
  </div>
</section>
